# Example Environment Variables for Local/Cloud Testing

# The Multiaddress of your Relay server. 
# For local testing, it looks like: /ip4/127.0.0.1/tcp/9002/p2p/<RELAY_ID>
# For Render WebSocket, it looks like: /dns4/<YOUR_APP>.onrender.com/tcp/443/wss/p2p/<RELAY_ID>
RELAY_ADDR=/ip4/127.0.0.1/tcp/9002/p2p/12D3KooW...

# The ID of Peer 1 (used by Peer 2 to target a connection)
PEER1_ID=12D3KooW...
